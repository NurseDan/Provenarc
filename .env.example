# ── Database ──────────────────────────────────────────────────────────────────
# Required. PostgreSQL connection string.
DATABASE_URL=postgresql://user:password@localhost:5432/provenarc

# ── Server ────────────────────────────────────────────────────────────────────
# Required in production. Long random string used to sign session cookies.
SESSION_SECRET=change-me-to-a-long-random-string

# Optional. Defaults to 5000.
PORT=5000

# Optional. Set to "production" in production environments.
NODE_ENV=development

# ── Site ──────────────────────────────────────────────────────────────────────
# Used in emails and sitemap generation.
SITE_URL=https://provenarc.com

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# If not set, email sending is skipped and content is logged to console.
# Supports any SMTP provider (Gmail, SendGrid, Postmark, Mailgun, etc.)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# Address emails are sent from.
FROM_EMAIL=noreply@provenarc.com

# Internal team address for quote/contact notifications.
ADMIN_EMAIL=info@provenarc.com
